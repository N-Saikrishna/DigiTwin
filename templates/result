<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADT | Simulation Results</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
    <header class="top-nav">
        <a href="/" class="pill-btn">← Home</a>
        <a href="/survey" class="pill-btn">New Simulation</a>
    </header>

    <main class="container">
        <section class="welcome-section">
            <h1>Digital Twin <strong>Analysis</strong></h1>
            
            <div class="info-card" style="text-align: left;">
                <h2 style="margin-bottom: 20px; border-bottom: 2px solid black;">Results for {{ student.student_name }}</h2>
                
                <div class="result-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <p><strong>Predicted GPA:</strong> {{ prediction.projected_gpa }}</p>
                        <p><strong>Academic Risk:</strong> {{ prediction.risk_score }}%</p>
                    </div>
                    <div>
                        <p><strong>Burnout Probability:</strong> {{ prediction.burnout_probability }}%</p>
                        <p><strong>Current Baseline:</strong> {{ student.current_gpa }}</p>
                    </div>
                </div>

                <div style="margin-top: 30px; background: rgba(255,255,255,0.3); padding: 20px; border-radius: 15px;">
                    <h3>Twin Recommendations:</h3>
                    <ul style="margin-left: 20px; margin-top: 10px;">
                        {% for rec in prediction.recommendations %}
                            <li>{{ rec }}</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            <p style="font-style: italic; font-size: 0.8rem; margin-top: 20px;">
                *This simulation is powered by a Linear Regression model trained on student habit patterns.
            </p>
        </section>
    </main>

    <div class="pegasus-corner">
        <img src="{{ url_for('static', filename='pegasus.png') }}" alt="UCF Pegasus" class="logo">
    </div>
</body>
</html>
